# =============================================================================
# ARaaS — Chatbot LLM provider configuration (Vite build-time env)
# =============================================================================
#
# Copy this file to `.env.local` for local development, or configure the same
# variables as repository / environment secrets in GitHub Actions.
#
# ⚠️  IMPORTANT — These are PUBLIC at runtime.
# Vite inlines every variable that starts with `VITE_` directly into the
# bundled JavaScript shipped to the browser. Anyone visiting the site can
# read them. Therefore:
#
#   • For the public GitHub Pages demo, leave these BLANK and let users add
#     their own keys via the in-app ⚙️ settings modal (Bring-Your-Own-Key,
#     stored in localStorage, never committed).
#
#   • Only set real keys here for personal / private deployments where the
#     bundle is not publicly accessible.
#
# -----------------------------------------------------------------------------

# Default provider when no per-user config exists.
# One of: openai | gemini | anthropic | mock
VITE_LLM_PROVIDER=mock

# Default model id (provider-specific). Leave blank to use the built-in default.
VITE_LLM_MODEL=

# Provider keys (set ONLY the one matching VITE_LLM_PROVIDER).
VITE_OPENAI_API_KEY=
VITE_GEMINI_API_KEY=
VITE_ANTHROPIC_API_KEY=
